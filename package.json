{
  "name": "nutrimania-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build:prod": "set APP_ENV=production&&next build",
    "build:dev": "set APP_ENV=development&&next build",
    "start": "next start",
    "lint": "next lint",
    "lint-fix": "concurrently \"npx eslint src --fix --ext .ts,.tsx\" \"npx prettier src --write --ignore-unknown\"",
    "format": "prettier --check --ignore-path .gitignore .",
    "format:fix": "prettier --write --ignore-path .gitignore .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.2.1",
    "@types/styled-components": "^5.1.34",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-simple-import-sort": "^12.0.0",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "next": "14.2.3",
    "next-yandex-metrica": "^1.1.2",
    "pdfjs-dist": "^4.7.76",
    "react": "^18",
    "react-calendar": "^5.0.0",
    "react-dom": "^18",
    "react-dropzone": "^14.2.9",
    "react-highlight-words": "^0.20.0",
    "react-hook-form": "^7.51.2",
    "react-image-file-resizer": "^0.4.8",
    "react-query": "^3.39.3",
    "react-redux": "^9.1.0",
    "recharts": "^2.12.6",
    "styled-components": "^6.1.8",
    "swiper": "^11.1.0",
    "usehooks-ts": "^3.0.1"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^14.1.1",
    "@types/lodash": "^4.17.5",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-highlight-words": "^0.20.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.1.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.0.11",
    "typescript": "^5.3.3",
    "typescript-eslint": "^7.1.0"
  }
}
